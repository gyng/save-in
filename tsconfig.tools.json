{
  "compilerOptions": {
    "noEmit": true,
    "target": "es2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "types": ["node", "vitest/globals"],
    "strict": true,
    // JS tooling has no declaration layer yet; retain inference while checking
    // real property, call-shape, module, and control-flow errors.
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": false
  },
  "include": [
    "scripts/**/*.js",
    "e2e/**/*.mjs",
    "rolldown.config.mjs",
    "vitest.config.mjs",
    "vitest.e2e.config.mjs"
  ]
}
