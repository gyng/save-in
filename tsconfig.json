{
  // Check-only setup for the bundled ESM/TypeScript codebase.
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "lib": ["es2023", "dom"],
    "types": ["firefox-webext-browser", "chrome", "node", "vitest/globals"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "src/**/*.ts", "test/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["src/vendor"]
}
