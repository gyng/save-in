{
  "name": "save-in",
  "version": "4.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build:bundled",
    "bundle": "node scripts/bundle.js --mode=production",
    "build:bundled": "node scripts/build-bundled.js && node scripts/package-runtime.js",
    "build:source": "node scripts/build-source-package.js",
    "bench:memory": "node scripts/profile-memory.js --report-only",
    "stage:bundled": "node scripts/build-bundled.js",
    "package:runtime": "node scripts/package-runtime.js",
    "check:architecture": "node scripts/check-import-cycles.js",
    "check:css": "node scripts/check-css.js",
    "check:css-cascade": "node scripts/check-css-cascade.js",
    "check:coverage-policy": "node scripts/check-coverage-policy.js",
    "check:e2e-harness": "node scripts/check-e2e-harness.js",
    "check:web-ext": "node scripts/check-web-ext.js",
    "check:i18n": "node scripts/check-i18n.js",
    "check:reference": "node scripts/check-reference-vocabulary.js",
    "check:release-package": "node scripts/build-bundled.js && node scripts/check-release-package.js",
    "check:release-package:staged": "node scripts/check-release-package.js",
    "check:test-layout": "node scripts/check-test-layout.js",
    "clean": "node scripts/clean-generated.js",
    "release:prepare": "node scripts/prepare-release.js",
    "d": "node scripts/dev-firefox.js",
    "d:chrome": "node scripts/dev-chrome.js --watch",
    "dogfood:functional": "node scripts/dogfood-functional.js",
    "dogfood:functional:watch": "node scripts/dogfood-functional.js --watch",
    "e2e": "node scripts/e2e-parallel.js",
    "e2e:headed": "node scripts/e2e-parallel.js --headed",
    "e2e:rss": "node scripts/e2e-parallel.js --test-name \"history rewrites keep browser RSS\"",
    "e2e:serial": "node scripts/e2e-parallel.js --serial",
    "e2e:chrome": "node scripts/e2e-parallel.js --browser=chrome",
    "e2e:chrome:headed": "node scripts/e2e-parallel.js --browser=chrome --headed",
    "e2e:firefox": "node scripts/e2e-parallel.js --browser=firefox",
    "e2e:firefox:headed": "node scripts/e2e-parallel.js --browser=firefox --headed",
    "e2e:compare": "node scripts/compare-e2e-timings.js",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "npm run typecheck && npm run stage:bundled && npm run lint:staged",
    "lint:staged": "npm run check:architecture && npm run check:test-layout && npm run check:e2e-harness && npm run check:coverage-policy && npm run check:css && npm run check:css-cascade && npm run lint:css && npm run check:i18n && npm run check:reference && npm run check:release-package:staged && npm run check:web-ext && oxlint --deny-warnings --report-unused-disable-directives-severity=error && npm run lint:type-aware && oxfmt --check",
    "lint:fix": "biome lint --write . && oxlint --fix && oxfmt",
    "lint:css": "biome lint --error-on-warnings .",
    "lint:type-aware": "oxlint --type-aware -A all -D typescript/no-for-in-array -D typescript/no-implied-eval -D typescript/no-meaningless-void-operator",
    "review": "node scripts/review-demo.js",
    "screenshots:store": "node scripts/generate-store-screenshots.js",
    "promo:store": "node scripts/generate-store-promo.js",
    "probe:symlink": "node scripts/platform-symlink-probe.js",
    "reload": "node scripts/reload.js",
    "test": "vitest run --config config/vitest/unit.mjs",
    "test:all": "vitest run --config config/vitest/base.mjs && npm run test:memory",
    "test:coverage": "vitest run --config config/vitest/base.mjs --coverage",
    "test:fuzz": "vitest run --config config/vitest/fuzz.mjs",
    "test:integration": "vitest run --config config/vitest/integration.mjs",
    "test:live": "vitest run --config config/vitest/live.mjs",
    "test:memory": "node scripts/profile-memory.js",
    "test:profile": "node scripts/profile-tests.js",
    "test:watch": "vitest --config config/vitest/unit.mjs",
    "typecheck": "tsc --noEmit -p config/typescript/browser.json && tsc --noEmit -p config/typescript/chrome.json && tsc --noEmit -p config/typescript/worker.json && tsc --noEmit -p config/typescript/tools.json && tsc --noEmit -p config/typescript/dev-tools.json && tsc --noEmit -p config/typescript/e2e.json && tsc --noEmit -p config/typescript/test.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@fast-check/vitest": "^0.4.1",
    "@types/chrome": "^0.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "acorn": "8.17.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "jszip": "3.10.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "rolldown": "^1.2.0",
    "typescript": "^7.0.2",
    "vitest": "4.1.10",
    "web-ext": "^10.4.0"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "shell-quote": "1.10.0"
  },
  "engines": {
    "node": ">=24"
  }
}
