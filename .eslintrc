{
  "env": {
    "browser": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "extends": ["airbnb", "prettier"],
  "plugins": ["prettier"],
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "env": { "node": true, "browser": false },
      "rules": {
        "no-console": 0,
        "global-require": 0,
        "no-await-in-loop": 0,
        "no-restricted-syntax": 0
      }
    },
    {
      "files": ["test/**/*.js"],
      "env": { "jest": true, "node": true },
      "rules": {
        "global-require": 0,
        "no-await-in-loop": 0
      }
    }
  ],
  "rules": {
    "prettier/prettier": "error",
    "max-classes-per-file": 0,
    "no-else-return": 0,
    "no-param-reassign": 0,
    "prefer-destructuring": 0,
    "prefer-object-spread": 0,
    "import/extensions": 0,
    "prefer-regex-literals": 0,
    "react/function-component-definition": 0,
    "react/destructuring-assignment": 0
  },
  "globals": {
    "globalChromeState": false,
    "getFilenameFromContentDispositionHeader": false,

    "Path": false,
    "Download": false,
    "Variable": false,
    "Messaging": false,
    "OptionsManagement": false,
    "Notification": false,
    "Menus": false,
    "Headers": false,
    "SessionState": false,
    "Shortcut": false,
    "Router": false,
    "SaveHistory": false,
    "Log": false,
    "options": false,
    "currentTab": false,
    "requestedDownloadFlag": true,
    "lastUsedPath": true,

    "SPECIAL_DIRS": false,
    "RULE_TYPES": false,
    "PATH_SEGMENT_TYPES": false,
    "SHORTCUT_EXTENSIONS": false,
    "SHORTCUT_TYPES": false,
    "MESSAGE_TYPES": false,
    "DOWNLOAD_TYPES": false,
    "MEDIA_TYPES": false,
    "OPTION_KEYS": false,
    "OPTION_TYPES": false,
    "CLICK_TYPES": false,

    "BROWSERS": false,
    "CURRENT_BROWSER": false,
    "BROWSER_FEATURES": false,
    "CURRENT_BROWSER_VERSION": false,

    "addClickToCopy": false
  }
}
