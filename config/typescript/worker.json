{
  "extends": "./chrome.json",
  "compilerOptions": {
    "lib": ["es2023", "webworker"],
    "types": ["firefox-webext-browser", "chrome"],
    // Both upstream WebExtension declaration packages mention a few DOM-only
    // types even for APIs available in workers. App source remains checked.
    "skipLibCheck": true
  },
  "include": ["../../src/entries/background.ts", "../../types/**/*.d.ts"],
  "exclude": ["../../types/host-firefox.d.ts"]
}
