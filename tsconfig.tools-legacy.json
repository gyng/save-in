{
  "extends": "./tsconfig.tools.json",
  "compilerOptions": {
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["scripts/**/*.js", "e2e/**/*.mjs"],
  "exclude": ["scripts/build-bundled.js", "scripts/with-env.js", "scripts/write-version.js"]
}
