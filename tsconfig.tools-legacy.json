{
  "extends": "./tsconfig.tools.json",
  "compilerOptions": {
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["scripts/**/*.js", "e2e/**/*.mjs"],
  "exclude": [
    "scripts/build-bundled.js",
    "scripts/build-source-package.js",
    "scripts/check-import-cycles.js",
    "scripts/prepare-release.js",
    "scripts/lib/architecture-checks.js",
    "scripts/lib/canonicalize-zip.js",
    "scripts/lib/package-metadata.js",
    "scripts/package-runtime.js",
    "scripts/with-env.js"
  ]
}
