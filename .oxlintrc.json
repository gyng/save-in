{
  "env": {
    "browser": true,
    "webextensions": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": [
      "warn",
      {
        "caughtErrors": "none"
      }
    ],
    "unicorn/consistent-function-scoping": "off"
  },
  "ignorePatterns": [
    "src/vendor",
    "src/options/vendor",
    "web-ext-artifacts",
    "dist",
    "docs",
    "test/mockserver"
  ],
  "overrides": [
    {
      "files": ["scripts/**/*.js", "scripts/**/*.mjs"],
      "env": {
        "node": true
      },
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["test/**/*.js", "test/**/*.mjs"],
      "env": {
        "node": true,
        "vitest": true
      },
      "globals": {
        "jest": "readonly"
      }
    },
    {
      "files": ["e2e/**/*.mjs"],
      "env": {
        "node": true,
        "vitest": true
      }
    }
  ]
}
