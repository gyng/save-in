{"manifest_version": 3, "name": "Save In", "version": "1.0", "description": "An extension to save items easily.", "permissions": ["contextMenus", "downloads", "storage", "tabs"], "background": {"service_worker": "background.js"}, "action": {"default_popup": "popup.html", "default_icon": "icons/icon.png"}, "content_scripts": [{"matches": ["<all_urls>"], "js": ["content.js"]}], "options_page": "options.html", "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}, "web_accessible_resources": [{"resources": ["icons/icon.png"], "matches": ["<all_urls>"]}]}