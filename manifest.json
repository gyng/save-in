{\n  ".manifest_version": 3,\n  "name": "Your Extension Name",\n  "description": "Your Extension Description",\n  "version": "1.0.0",\n  "permissions": [\n    "storage",\n    "tabs"\n  ],\n  "host_permissions": [\n    "https://*/*",\n    "http://*/*"\n  ],\n  "background": {\n    "service_worker": "background.js"\n  },\n  "action": {\n    "default_popup": "popup.html",\n    "default_icon": {\n      "16": "icons/icon16.png",\n      "48": "icons/icon48.png",\n      "128": "icons/icon128.png"\n    }\n  },\n  "web_accessible_resources": [{\n    "resources": [\n      "icons/*",\n      "*.css",\n      "*.js"\n    ],\n    "matches": [\n      "*://*/*"\n    ]\n  }],\n  "icons": {\n    "16": "icons/icon16.png",\n    "48": "icons/icon48.png",\n    "128": "icons/icon128.png"\n  }\n}