{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "4.0.0",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "{72d92df5-2aa0-4b06-b807-aa21767545cd}",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "homepage_url": "https://github.com/gyng/save-in",
  "minimum_chrome_version": "123",
  "background": {
    "scripts": [
      "src/web-extension-api.js",
      "src/vendor/content-disposition.js",
      "src/chrome-detector.js",
      "src/constants.js",
      "src/util.js",
      "src/session-state.js",
      "src/log.js",
      "src/history.js",
      "src/counter.js",
      "src/download-state.js",
      "src/notification.js",
      "src/path.js",
      "src/offscreen-client.js",
      "src/download.js",
      "src/router.js",
      "src/shortcut.js",
      "src/messaging.js",
      "src/headers.js",
      "src/variable.js",
      "src/menu-build.js",
      "src/menu-click.js",
      "src/menu-tabs.js",
      "src/option.js",
      "src/index.js"
    ],
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],
  "permissions": ["contextMenus", "downloads", "notifications", "storage", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "List page sources",
    "default_icon": {
      "48": "icons/ic_archive_black_48px.png",
      "96": "icons/ic_archive_black_96px.png"
    }
  },
  "commands": {
    "toggle-source-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle the Page Sources browser"
    }
  },
  "icons": {
    "48": "icons/ic_archive_black_48px.png",
    "96": "icons/ic_archive_black_96px.png",
    "128": "icons/ic_archive_black_128px.png"
  }
}
