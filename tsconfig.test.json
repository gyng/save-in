{
  "extends": "./tsconfig.browser.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "types": ["firefox-webext-browser", "chrome", "node", "vitest/globals"]
